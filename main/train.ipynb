import torch
import numpy as np
from torchvision import datasets, transforms, models
from torch.utils.data import DataLoader, Subset
from sklearn.model_selection import StratifiedKFold
from sklearn.metrics import f1_score
import torch.nn as nn
from torch.cuda.amp import autocast, GradScaler

# --------------------
# 1. SETUP
# --------------------
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"Running on: {device}")

DATA_PATH = "/kaggle/input/competitions/kaggle-hac-x-26-data-sprint-to-the-peak/cassava_leaf_disease_classification/data"

BATCH_SIZE = 32
EPOCHS = 3
FOLDS = 3
LR = 3e-4
BEST_MODEL_PATH = "efficientnet_best.pth"

# --------------------
# 2. TRANSFORMS
# --------------------
# Optimized for EfficientNet-B0 (Standard 224x224 input)
train_tfms = transforms.Compose([
    transforms.RandomResizedCrop(224),
    transforms.RandomHorizontalFlip(),
    transforms.RandomVerticalFlip(), # Added for leaf orientation variety
    transforms.RandomRotation(15),
    transforms.ColorJitter(brightness=0.1, contrast=0.1),
    transforms.ToTensor(),
    transforms.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225])
])

val_tfms = transforms.Compose([
    transforms.Resize(256),
    transforms.CenterCrop(224),
    transforms.ToTensor(),
    transforms.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225])
])

# --------------------
# 3. DATASET INITIALIZATION
# --------------------
# Load base dataset once to get targets for stratification
base_dataset = datasets.ImageFolder(root=DATA_PATH)
targets = np.array(base_dataset.targets)
skf = StratifiedKFold(n_splits=FOLDS, shuffle=True, random_state=42)

global_best_f1 = 0.0

# --------------------
# 4. K-FOLD LOOP
# --------------------
for fold, (train_idx, val_idx) in enumerate(skf.split(np.zeros(len(targets)), targets)):
    print(f"\n{'='*10} FOLD {fold+1} {'='*10}")

    # Re-instantiate with specific transforms to avoid leakage
    train_ds = Subset(datasets.ImageFolder(DATA_PATH, transform=train_tfms), train_idx)
    val_ds = Subset(datasets.ImageFolder(DATA_PATH, transform=val_tfms), val_idx)

    # Calculate class weights for the current fold to handle imbalance
    train_targets = targets[train_idx]
    class_counts = np.bincount(train_targets)
    # weights = 1 / counts
    class_weights = torch.tensor(1.0 / class_counts, dtype=torch.float).to(device)

    # Loaders with pin_memory for faster GPU transfer
    train_loader = DataLoader(train_ds, batch_size=BATCH_SIZE, shuffle=True, 
                              num_workers=4, pin_memory=True)
    val_loader = DataLoader(val_ds, batch_size=BATCH_SIZE, shuffle=False, 
                            num_workers=4, pin_memory=True)

    # --------------------
    # 5. MODEL (EfficientNet-B0)
    # --------------------
    model = models.efficientnet_b0(weights=models.EfficientNet_B0_Weights.DEFAULT)
    
    # Customize head for 5 classes
    model.classifier = nn.Sequential(
        nn.Dropout(p=0.4, inplace=True),
        nn.Linear(model.classifier[1].in_features, 5)
    )
    model = model.to(device)

    # --------------------
    # 6. OPTIMIZER & LOSS
    # --------------------
    criterion = nn.CrossEntropyLoss(weight=class_weights)
    optimizer = torch.optim.Adam(model.parameters(), lr=LR)
    scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=EPOCHS)
    scaler = GradScaler(enabled=(device.type == "cuda"))

    # --------------------
    # 7. TRAINING
    # --------------------
    for epoch in range(EPOCHS):
        model.train()
        running_loss = 0.0
        
        for images, labels in train_loader:
            images, labels = images.to(device, non_blocking=True), labels.to(device, non_blocking=True)

            optimizer.zero_grad()
            with autocast(enabled=(device.type == "cuda")):
                outputs = model(images)
                loss = criterion(outputs, labels)

            scaler.scale(loss).backward()
            scaler.step(optimizer)
            scaler.update()
            running_loss += loss.item()

        # Validation
        model.eval()
        all_preds, all_labels = [], []
        with torch.no_grad():
            for images, labels in val_loader:
                images = images.to(device, non_blocking=True)
                outputs = model(images)
                preds = torch.argmax(outputs, 1)
                all_preds.extend(preds.cpu().numpy())
                all_labels.extend(labels.numpy())

        f1 = f1_score(all_labels, all_preds, average='weighted')
        print(f"Epoch {epoch+1}/{EPOCHS} | Train Loss: {running_loss/len(train_loader):.4f} | Val F1: {f1:.4f}")
        
        scheduler.step()

        # Save absolute best across all folds
        if f1 > global_best_f1:
            global_best_f1 = f1
            torch.save(model.state_dict(), BEST_MODEL_PATH)
            print(">>> Saved New Best Model State")

print(f"\nFinal Best F1 Score: {global_best_f1:.4f}")



